{
  "name": "meme-ai-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "initializeCommand": "test -f \"${localWorkspaceFolder}/.env\" || cp \"${localWorkspaceFolder}/.env.example\" \"${localWorkspaceFolder}/.env\"",
  "postCreateCommand": "chmod +x .devcontainer/postCreateCommand.sh && ./.devcontainer/postCreateCommand.sh",
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],
  "remoteUser": "vscode",
  "forwardPorts": [8000, 5173],
  "portsAttributes":{
    "8000": {
      "label": "FastAPI Development Server"
    },
    "5173": {
      "label": "Vite Development Server"
    }
  },
  "mounts": [
      "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
      "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
      "source=${localEnv:HOME}/.claude/plugins/installed_plugins.json,target=/home/vscode/.claude/plugins/installed_plugins.json,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions",
        "mhutchie.git-graph",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.live-server",
        "openai.chatgpt",
        "ryu1kn.partial-diff",
        "streetsidesoftware.code-spell-checker",
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
